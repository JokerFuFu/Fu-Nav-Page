{
  "manifest_version": 3,
  "name": "Fu 导航",
  "version": "3.22.0",
  "description": "浏览器首页导航 · 极简AI搜索/分组 · 真实图标 · 时钟天气 · 一键收藏当前页(已收藏角标提示) · 书签双向同步 · 多端同步 · homelab 面板。",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_title": "收藏当前网页到 Fu 导航",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "bookmarks",
    "favicon",
    "activeTab",
    "tabs",
    "identity"
  ],
  "host_permissions": [
    "http://127.0.0.1:7842/*",
    "https://ipwho.is/*",
    "https://get.geojs.io/*",
    "https://api.open-meteo.com/*",
    "https://www.googleapis.com/*",
    "https://www.bing.com/*",
    "https://*.alcy.cc/*"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
